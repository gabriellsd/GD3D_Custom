# --- Supabase Auth (recomendado) ---
# Corra: npm run supabase:setup
# Ou copie este ficheiro para .env e preencha os valores.

# Segredo do cookie de sessão do site (mín. 16 caracteres). Obrigatório na Vercel.
AUTH_SECRET=altere-isto-para-um-segredo-longo-e-aleatorio

# Painel Supabase → Project Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
# Publishable key (NÃO use service_role nem secret key)
VITE_SUPABASE_ANON_KEY=sua-publishable-key

# Painel Supabase → Project Settings → API → JWT Settings → JWT Secret
# Só no servidor — NUNCA no frontend nem no Git
SUPABASE_JWT_SECRET=seu-jwt-secret-do-supabase

# --- Fallback local (só se NÃO usar Supabase) ---
# AUTH_USERS=[{"email":"admin@gd3d.com","password":"***","role":"admin","name":"Admin"}]
# Em dev: copie auth.users.example.json → auth.users.json

# SQL no Supabase: supabase/setup.sql + supabase/catalog.sql

# Só para npm run catalog:seed (local) — NUNCA no frontend nem Vercel
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
