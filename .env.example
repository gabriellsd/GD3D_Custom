# --- Autenticação local (sem Supabase) ---
# Segredo para cookie de sessão (mín. 16 caracteres). Obrigatório na Vercel.
AUTH_SECRET=altere-isto-para-um-segredo-longo-e-aleatorio

# Utilizadores em produção (JSON numa linha), se NÃO usar Supabase:
# AUTH_USERS=[{"email":"admin@gd3d.com","password":"***","role":"admin","name":"Admin"}]

# Em dev local sem Supabase: copie auth.users.example.json → auth.users.json

# --- Supabase Auth (recomendado em produção) ---
# Painel Supabase → Project Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Painel Supabase → Project Settings → API → JWT Secret (só no servidor, NUNCA no frontend)
SUPABASE_JWT_SECRET=seu-jwt-secret-do-supabase

# Papéis admin/client: ver supabase/roles.sql (app_metadata.role)
